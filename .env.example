# ============================================================================
# The Money Button v2 — environment configuration.
# Copy to .env and fill in values. Never commit .env.
# Every setting here is validated at startup by src/moneybutton/core/config.py.
# ============================================================================

# --- Runtime safety ---------------------------------------------------------
# DRY_RUN=true disables real order placement and real content publishing.
# Keep this as "true" until a strategy has been explicitly promoted and you
# have typed "I ACCEPT THE RISK" via `python -m moneybutton live`.
DRY_RUN=true

# KALSHI_ENV=demo routes API calls to api.elections.kalshi.com/demo.
# Flip to "prod" only after DRY_RUN testing in demo.
KALSHI_ENV=demo

# --- Bankroll & risk caps (validated; hard ceilings enforced in code) -------
BANKROLL_USD=500
MAX_POSITION_USD=25
MAX_OPEN_POSITIONS=8
DAILY_LOSS_LIMIT_USD=50
MIN_TRADE_USD=5
MIN_LIQUIDITY_USD=500
KELLY_FRACTION=0.10

# --- Per-strategy allocation (fractions of BANKROLL_USD, must sum to <=1) ---
ALLOCATION_CALIBRATION=0.40
ALLOCATION_ARBITRAGE=0.25
ALLOCATION_CONSISTENCY=0.15
ALLOCATION_NEWS=0.10
ALLOCATION_DRIFT=0.10

# --- Strategy tuning knobs --------------------------------------------------
MIN_EDGE_BPS_CALIBRATION=500
SAFETY_MARGIN_BPS_ARBITRAGE=100
SLIPPAGE_BPS_BACKTEST=25

# --- Kalshi API -------------------------------------------------------------
# Your Kalshi API key id (email -> API Keys) and the path to the matching
# RSA private key (.pem). The private key file stays on your machine.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=data/kalshi_private_key.pem

# --- Polymarket (optional; enables arbitrage strategy) ----------------------
# Gamma API is public; CLOB requires a signed EVM wallet. Leave blank to
# operate in signals-only mode (no live arbitrage execution on Polymarket).
POLYMARKET_ENABLED=true
POLYMARKET_WALLET_PRIVATE_KEY=

# --- Sportsbook signals (optional, the-odds-api free tier = 500 req/mo) -----
ODDSAPI_ENABLED=true
ODDSAPI_KEY=

# --- News APIs --------------------------------------------------------------
# Free-tier limits: NewsAPI 100 req/day, EventRegistry 2000 events/day.
NEWSAPI_KEY=
EVENTREGISTRY_KEY=

# --- Anthropic / LLM --------------------------------------------------------
ANTHROPIC_API_KEY=
LLM_MODEL_GENERAL=claude-opus-4-7
LLM_MODEL_NEWS=claude-haiku-4-5

# --- Content publishers -----------------------------------------------------
# Leave DEVTO_API_KEY blank to route everything to data/outbox/ for manual
# review. AUTO_PUBLISH_DEVTO=false keeps articles as published:false drafts.
DEVTO_API_KEY=
AUTO_PUBLISH_DEVTO=false

# --- Notifications ----------------------------------------------------------
# Leave blank for log-only notifications (see logs/moneybutton.log).
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# --- Scheduling -------------------------------------------------------------
TIMEZONE=America/New_York

# --- Paths (overridable, sensible defaults) ---------------------------------
DATA_DIR=data
LOGS_DIR=logs
SQLITE_PATH=data/moneybutton.db
KILL_FILE=.kill
